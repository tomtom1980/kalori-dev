# Kalori — environment variable template
# Copy this file to .env.local and populate values from Planning/devapikeys.txt (gitignored).
# Production values live in Planning/apikeys.txt (gitignored) and are already populated in Vercel.

# Runtime env
KALORI_ENV=development
# Client-visible mirror of KALORI_ENV — required so the browser Sentry bundle
# tags events correctly (without NEXT_PUBLIC_ prefix, KALORI_ENV is stripped
# from the client bundle and Sentry defaults environment to "production").
NEXT_PUBLIC_KALORI_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (canonical 2026 key names) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# Direct-connection DB URL for migrations (port 5432). Not for app runtime.
DATABASE_URL_DIRECT=

# --- Gemini (server-only; I3 enforced by eslint-rules/no-gemini-leak.js) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
# Codex R1 I3 (Task 4.7.6) — secondary model for the vn-smoke fallback chain.
# Optional override; defaults to `gemini-2.5-flash-lite` when unset. Server-only.
# KALORI_AI_FALLBACK_MODEL=gemini-2.5-flash-lite

# --- Sentry ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=kalori
SENTRY_PROJECT=kalori-dev

# --- Google OAuth (Task 2.1 — configured in Supabase Auth + Vercel) ---
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# --- Vercel Preview SSO bypass (Task 1.1 — for Playwright E2E against preview URLs) ---
# VERCEL_AUTOMATION_BYPASS_SECRET=

# --- Test (CI-only, for reference) ---
# SUPABASE_TEST_URL=
# SUPABASE_TEST_ANON_KEY=
# SUPABASE_TEST_SERVICE_ROLE_KEY=
# GEMINI_TEST_API_KEY=
# VERCEL_TOKEN=
# The F-TEST-4 Playwright auth fixture (tests/e2e/fixtures/auth.ts) provisions
# a fresh test user per test via supabase.auth.admin.createUser. No
# TEST_USER_EMAIL / TEST_USER_PASSWORD env vars are needed — the fixture
# generates a timestamped email + random suffix and uses a built-in test
# password. Reuses SUPABASE_TEST_URL + SUPABASE_TEST_ANON_KEY +
# SUPABASE_TEST_SERVICE_ROLE_KEY above (falls back to NEXT_PUBLIC_SUPABASE_URL
# + NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY + SUPABASE_SECRET_KEY for local dev).
