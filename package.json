{
  "name": "kalori",
  "version": "0.1.0",
  "private": true,
  "description": "Kalori — AI-first calorie/nutrition tracker (PWA, dark-only, single-user).",
  "engines": {
    "node": "20.x"
  },
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "next dev",
    "build": "next build && pnpm sw:build",
    "build:analyze": "ANALYZE=true next build && pnpm sw:build",
    "sw:build": "node scripts/build-sw.mjs",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --pool threads --maxWorkers 1",
    "test:watch": "vitest --pool threads --maxWorkers 1",
    "test:unit": "vitest run --pool threads --maxWorkers 1 tests/unit",
    "test:coverage": "vitest run --pool threads --maxWorkers 1 --coverage",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test --project=chromium tests/axe",
    "check:bundle-budget": "node scripts/check-bundle-budget.mjs",
    "seed": "tsx scripts/seed.ts",
    "icons": "tsx scripts/generate-pwa-icons.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.49.0",
    "@serwist/next": "^9.5.7",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "archiver": "^7.0.1",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "serwist": "^9.5.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@lhci/cli": "0.15.1",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/archiver": "^7.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "babel-plugin-react-compiler": "1.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^16.2.4",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "msw": "^2.13.4",
    "postcss": "^8.4.49",
    "prettier": "^3.4.1",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.4",
    "vitest-axe": "^0.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
