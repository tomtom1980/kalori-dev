name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]
  # Task 5.1.8 — manual baseline regeneration toggle. Maintainers trigger via
  # GitHub UI ("Run workflow" → toggle update_snapshots=true) when a
  # deliberate UI change requires regenerating visual baselines. The visual
  # job consumes `inputs.update_snapshots` and passes
  # `--update-snapshots=missing` when true; resulting PNGs ship in the
  # `visual-report` artifact for the maintainer to download + commit.
  workflow_dispatch:
    inputs:
      update_snapshots:
        description: 'Regenerate visual baselines (downloads new PNGs as artifact)'
        required: false
        default: 'false'
        type: choice
        options:
          - 'false'
          - 'true'

concurrency:
  group: ci-${{ github.ref }}
  cancel-in-progress: true

env:
  NODE_VERSION: 20

jobs:
  lint-typecheck:
    name: Lint + Typecheck
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v5
      - uses: pnpm/action-setup@v4
        with:
          run_install: false
      - uses: actions/setup-node@v5
        with:
          node-version: ${{ env.NODE_VERSION }}
          cache: pnpm
      - run: pnpm install --frozen-lockfile
      - run: pnpm lint
      - run: pnpm typecheck

  format-check:
    name: Format check
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v5
      - uses: pnpm/action-setup@v4
        with:
          run_install: false
      - uses: actions/setup-node@v5
        with:
          node-version: ${{ env.NODE_VERSION }}
          cache: pnpm
      - run: pnpm install --frozen-lockfile
      - run: pnpm format:check

  gemini-key-leak-guard:
    name: gemini-key-leak-guard
    runs-on: ubuntu-latest
    needs: [lint-typecheck, format-check]
    steps:
      - uses: actions/checkout@v5
      - name: grep-level scan for Gemini references outside allowlist
        shell: bash
        run: |
          set -euo pipefail
          offenders=$(
            {
              grep -rEn --include='*.ts' --include='*.tsx' '@google/generative-ai|generative-ai' app components lib 2>/dev/null || true
              grep -rEn --include='*.ts' --include='*.tsx' 'GEMINI_API_KEY' app components lib 2>/dev/null || true
            } \
            | { grep -vE '^(lib/ai/|app/api/|lib/server/)|tests/fixtures' || true; } \
            | sort -u
          )
          if [ -n "${offenders}" ]; then
            echo "::error::Gemini references found outside lib/ai/ · app/api/ · lib/server/ · test fixtures:"
            echo "${offenders}"
            exit 1
          fi
          echo "No offending references."

  unit-integration:
    name: Unit + Integration (Vitest)
    runs-on: ubuntu-latest
    needs: [lint-typecheck, format-check, gemini-key-leak-guard]
    steps:
      - uses: actions/checkout@v5
      - uses: pnpm/action-setup@v4
        with:
          run_install: false
      - uses: actions/setup-node@v5
        with:
          node-version: ${{ env.NODE_VERSION }}
          cache: pnpm
      - run: pnpm install --frozen-lockfile
      - run: pnpm test:coverage
        env:
          KALORI_ENV: test
          # Wire RLS harness env vars so `tests/rls/_harness.test.ts` actually
          # executes on Linux CI (was silently skipped prior to 2026-04-20).
          # Secrets set per setup-state.md §7.
          SUPABASE_TEST_URL: ${{ secrets.SUPABASE_TEST_URL }}
          SUPABASE_TEST_ANON_KEY: ${{ secrets.SUPABASE_TEST_ANON_KEY }}
          SUPABASE_TEST_SERVICE_ROLE_KEY: ${{ secrets.SUPABASE_TEST_SERVICE_ROLE_KEY }}
          # Management-API introspection for `library-tombstone.test.ts` migration
          # 0007 schema-shape assertions. PAT scoped to project read; ref points
          # at kalori-dev (CI uses dev DB per setup-state.md §1).
          SUPABASE_PAT: ${{ secrets.SUPABASE_PAT }}
          SUPABASE_PROJECT_REF: ${{ secrets.SUPABASE_PROJECT_REF }}
          # `lib/ai/client.ts#callGemini` throws "GEMINI_API_KEY is not set"
          # BEFORE reaching `fetch`, which means MSW never sees the request
          # and every AI integration test falls through to the I7 fallback
          # path. The MSW stubs in `tests/mocks/handlers.ts` intercept every
          # outbound Gemini request by URL pattern, so zero real traffic
          # reaches Google — the variable just needs to be a non-empty string.
          # We forward the existing GEMINI_TEST_API_KEY secret for parity
          # with the e2e/build jobs; no new secret required.
          GEMINI_API_KEY: ${{ secrets.GEMINI_TEST_API_KEY }}
      - uses: actions/upload-artifact@v4
        if: always()
        with:
          name: coverage
          path: coverage

  e2e:
    name: E2E (Playwright placeholder)
    runs-on: ubuntu-latest
    needs: [lint-typecheck, format-check, gemini-key-leak-guard, unit-integration]
    steps:
      - uses: actions/checkout@v5
      - uses: pnpm/action-setup@v4
        with:
          run_install: false
      - uses: actions/setup-node@v5
        with:
          node-version: ${{ env.NODE_VERSION }}
          cache: pnpm
      - run: pnpm install --frozen-lockfile
      - run: pnpm exec playwright install --with-deps chromium
      - run: pnpm build
        env:
          KALORI_ENV: test
          NEXT_PUBLIC_SUPABASE_URL: ${{ secrets.SUPABASE_TEST_URL }}
          NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY: ${{ secrets.SUPABASE_TEST_ANON_KEY }}
          SUPABASE_SECRET_KEY: ${{ secrets.SUPABASE_TEST_SERVICE_ROLE_KEY }}
          GEMINI_API_KEY: ${{ secrets.GEMINI_TEST_API_KEY }}
          NEXT_PUBLIC_SENTRY_DSN: ''
      - name: Start Next.js
        # Runtime env block must mirror the `pnpm build` step. NEXT_PUBLIC_*
        # vars get baked into the build output, but SUPABASE_SECRET_KEY +
        # GEMINI_API_KEY are read at runtime via `process.env.*` (no NEXT_PUBLIC
        # prefix → not bundled). Without them the Next.js server can construct
        # the anon client (NEXT_PUBLIC_* baked) but `getAdminSupabase()` throws,
        # which surfaces in the account-delete cascade as `cause: cascade_failed`.
        run: pnpm exec next start --port 3000 &
        env:
          KALORI_ENV: test
          NEXT_PUBLIC_SUPABASE_URL: ${{ secrets.SUPABASE_TEST_URL }}
          NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY: ${{ secrets.SUPABASE_TEST_ANON_KEY }}
          SUPABASE_SECRET_KEY: ${{ secrets.SUPABASE_TEST_SERVICE_ROLE_KEY }}
          GEMINI_API_KEY: ${{ secrets.GEMINI_TEST_API_KEY }}
          NEXT_PUBLIC_SENTRY_DSN: ''
      - name: Wait for dev server
        run: npx wait-on http://localhost:3000 -t 60000 || true
      # `--project=chromium` scopes Playwright to the E2E + axe project only.
      # The full `pnpm test:e2e` runs the visual matrix (chromium-baseline
      # × 3 viewports + Firefox + WebKit) which is owned by the dedicated
      # `visual` job below; running it here without the firefox/webkit
      # binaries installed produces 12 spurious "browser not found" failures
      # plus duplicate baseline runs.
      - run: pnpm exec playwright test --project=chromium
        env:
          CI: '1'
          PREVIEW_URL: http://localhost:3000
          # `tests/e2e/fixtures/auth.ts#resolveEnv` requires the SUPABASE_TEST_*
          # triple (admin createUser + signInWithPassword + service-role profile
          # patch). Mirror the visual job's env block so real-user-session specs
          # (fixtures-auth, library-*, axe-baseline, etc.) can provision their
          # ephemeral test users on `kalori-dev`. Build step env above is
          # step-scoped and does NOT propagate to this step.
          SUPABASE_TEST_URL: ${{ secrets.SUPABASE_TEST_URL }}
          SUPABASE_TEST_ANON_KEY: ${{ secrets.SUPABASE_TEST_ANON_KEY }}
          SUPABASE_TEST_SERVICE_ROLE_KEY: ${{ secrets.SUPABASE_TEST_SERVICE_ROLE_KEY }}
      - uses: actions/upload-artifact@v4
        if: always()
        with:
          name: playwright-report
          path: playwright-report

  visual:
    name: Visual regression (Linux Chromium baseline + advisory cross-browser)
    runs-on: ubuntu-latest
    # Independent of `unit-integration` per Task 5.1.8 D6 — visual regression
    # is orthogonal to Vitest unit/integration runs. Keeps the visual job
    # green even while `unit-integration` is in transient failure (which it
    # is at the time of 5.1.8 landing per continuation.md residual risk).
    needs: [lint-typecheck, format-check, gemini-key-leak-guard]
    steps:
      - uses: actions/checkout@v5
      - uses: pnpm/action-setup@v4
        with:
          run_install: false
      - uses: actions/setup-node@v5
        with:
          node-version: ${{ env.NODE_VERSION }}
          cache: pnpm
      - run: pnpm install --frozen-lockfile
      - run: pnpm exec playwright install --with-deps chromium firefox webkit
      - run: pnpm build
        env:
          KALORI_ENV: test
          NEXT_PUBLIC_SUPABASE_URL: ${{ secrets.SUPABASE_TEST_URL }}
          NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY: ${{ secrets.SUPABASE_TEST_ANON_KEY }}
          SUPABASE_SECRET_KEY: ${{ secrets.SUPABASE_TEST_SERVICE_ROLE_KEY }}
          GEMINI_API_KEY: ${{ secrets.GEMINI_TEST_API_KEY }}
          NEXT_PUBLIC_SENTRY_DSN: ''
      - name: Start Next.js
        run: pnpm exec next start --port 3000 &
        env:
          KALORI_ENV: test
      - name: Wait for dev server
        run: npx wait-on http://localhost:3000 -t 60000 || true
      # Optional baseline regeneration toggle. Maintainer dispatches the CI
      # workflow with `update_snapshots=true` (workflow_dispatch input) when
      # a deliberate UI change requires fresh baselines; downloads the
      # `visual-report` artifact from the run, commits the regenerated PNGs.
      - name: Visual regression — Chromium baseline (blocking)
        run: |
          if [ "${{ inputs.update_snapshots }}" = "true" ]; then
            pnpm exec playwright test \
              --project=visual-baseline-chromium \
              --project=visual-baseline-chromium-tablet \
              --project=visual-baseline-chromium-mobile \
              --update-snapshots=changed
          else
            pnpm exec playwright test \
              --project=visual-baseline-chromium \
              --project=visual-baseline-chromium-tablet \
              --project=visual-baseline-chromium-mobile
          fi
        env:
          CI: '1'
          PREVIEW_URL: http://localhost:3000
          SUPABASE_TEST_URL: ${{ secrets.SUPABASE_TEST_URL }}
          SUPABASE_TEST_ANON_KEY: ${{ secrets.SUPABASE_TEST_ANON_KEY }}
          SUPABASE_TEST_SERVICE_ROLE_KEY: ${{ secrets.SUPABASE_TEST_SERVICE_ROLE_KEY }}
      - name: Visual regression — Firefox + WebKit (advisory ≤0.5%)
        continue-on-error: true
        run: pnpm exec playwright test --project=visual-firefox --project=visual-safari
        env:
          CI: '1'
          PREVIEW_URL: http://localhost:3000
          SUPABASE_TEST_URL: ${{ secrets.SUPABASE_TEST_URL }}
          SUPABASE_TEST_ANON_KEY: ${{ secrets.SUPABASE_TEST_ANON_KEY }}
          SUPABASE_TEST_SERVICE_ROLE_KEY: ${{ secrets.SUPABASE_TEST_SERVICE_ROLE_KEY }}
      - uses: actions/upload-artifact@v4
        if: always()
        with:
          name: visual-report
          path: |
            playwright-report
            test-results
            tests/visual/__screenshots__

  build:
    name: Next build (with source maps)
    runs-on: ubuntu-latest
    # Strict gate order: (lint/typecheck + format-check run in parallel) →
    # guard → unit/integration → e2e → build. A broken test in ANY earlier
    # stage blocks the build job (which uploads source maps to Sentry), so
    # we never ship builds whose upstream signals haven't been verified.
    needs: [lint-typecheck, format-check, gemini-key-leak-guard, unit-integration, e2e]
    if: github.event_name == 'push'
    steps:
      - uses: actions/checkout@v5
      - uses: pnpm/action-setup@v4
        with:
          run_install: false
      - uses: actions/setup-node@v5
        with:
          node-version: ${{ env.NODE_VERSION }}
          cache: pnpm
      - run: pnpm install --frozen-lockfile
      - run: pnpm build
        env:
          KALORI_ENV: production
          SENTRY_AUTH_TOKEN: ${{ secrets.SENTRY_AUTH_TOKEN }}
          SENTRY_ORG: kalori
          SENTRY_PROJECT: kalori-prod
      # IF-3 (Task 4.1 Codex Fix Round 1): /library initial client JS
      # gzipped budget gate. Reads the App Router client-reference
      # manifest emitted by the preceding `pnpm build`, subtracts
      # (app)/layout overlap, and sums gzipped sizes of the remaining
      # library-specific chunks. Fails if the total exceeds
      # LIBRARY_BUNDLE_BUDGET_BYTES (default 110 KB — current
      # first-consumer baseline; see followups F-PERF-4.1-BUNDLE-28KB
      # for the 28 KB aspirational story).
      - run: pnpm check:bundle-budget
